generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String?
  passwordHash          String
  role                  String    @default("viewer")
  subscriptionTier      String    @default("free")
  subscriptionExpiresAt DateTime?

  videos                Video[]
  adWatches             AdWatch[]
  projects              Project[]

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Segment {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?

  videos      Video[]
  projects    Project[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Video {
  id              String    @id @default(cuid())

  title           String
  description     String?

  genre           String
  region          String
  type            String

  trailerClipUrl  String?
  fullVideoUrl    String?
  cloudflareUid   String?

  creatorId       String
  creator         User      @relation(fields: [creatorId], references: [id])

  segmentId       String?
  segment         Segment?  @relation(fields: [segmentId], references: [id])

  views           Int       @default(0)
  revenue         Float     @default(0)

  isPublished     Boolean   @default(false)
  status          String    @default("draft")

  adWatches       AdWatch[]

  episodeId       String?   @unique
  episode         Episode?  @relation(fields: [episodeId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([creatorId])
  @@index([segmentId])
  @@index([genre])
  @@index([region])
  @@index([status])
}

model Project {
  id          String    @id @default(cuid())
  title       String
  description String?
  genre       String
  region      String
  type        String    @default("series") // 👈 "movie" or "series"
  segmentId   String?
  segment     Segment?  @relation(fields: [segmentId], references: [id])
  coverImage  String?
  trailerUrl  String?

  creatorId   String
  creator     User      @relation(fields: [creatorId], references: [id])

  episodes    Episode[]
  views       Int       @default(0)
  revenue     Float     @default(0)
  status      String    @default("draft")
  isPublished Boolean   @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([creatorId])
  @@index([segmentId])
}

model Episode {
  id            String    @id @default(cuid())
  title         String
  description   String?
  episodeNumber Int
  videoUrl      String?
  thumbnail     String?
  duration      String?

  projectId     String
  project       Project   @relation(fields: [projectId], references: [id])

  videoId       String?   @unique
  video         Video?    // 👈 No @relation here (defined on Video side)

  views         Int       @default(0)
  status        String    @default("draft")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId])
  @@index([episodeNumber])
  @@index([status])
}

model AdWatch {
  id          String    @id @default(cuid())

  userId      String
  user        User      @relation(fields: [userId], references: [id])

  videoId     String
  video       Video     @relation(fields: [videoId], references: [id])

  completed   Boolean   @default(false)

  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([videoId])
}